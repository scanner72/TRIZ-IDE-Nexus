{
  "name": "triz-mcp-server",
  "version": "0.1.0",
  "private": true,
  "description": "Local TRIZ MCP orchestration server for TRIZ-IDE Nexus",
  "type": "module",
  "main": "dist/src/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/src/index.js",
    "check": "tsc --noEmit -p tsconfig.json",
    "test": "node --test dist/tests/**/*.test.js"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "fastify": "^5.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
